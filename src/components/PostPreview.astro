---
import DateFormatter from "./DateFormatter.astro";

interface Props {
  title: string;
  date: string;
  excerpt?: string;
  slug: string;
}

const { title, date, excerpt, slug } = Astro.props;
---

<div style="grid-template-columns: auto 1fr" class="grid gap-4 items-center">
  <div class="bg-gray-700 w-3 h-3 rounded-full m-2"></div>
  <div>
    <h2 class="text-3xl mb-3 leading-snug">
      <a href={`/posts/${slug}/`} class="hover:underline" title={excerpt}>
        {title}
      </a>
    </h2>
    <div class="text-lg italic">
      <DateFormatter dateString={date} />
    </div>
  </div>
</div>
