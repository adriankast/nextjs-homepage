---
import PostPreview from "./PostPreview.astro";
import type { Post } from "../lib/posts";

interface Props {
  posts: Post[];
}

const { posts } = Astro.props;
---

<div class="flex justify-center">
  <section class="w-fit">
    <h1
      class="mb-8 text-6xl md:text-7xl font-bold tracking-tighter leading-tight"
    >
      More Posts
    </h1>
    <div
      class="grid grid-cols-1 md:gap-x-16 lg:gap-x-32 gap-y-20 md:gap-y-32 mb-32"
    >
      {
        posts.map((post) => (
          <PostPreview
            title={post.data.title}
            date={post.data.date}
            slug={post.id}
            excerpt={post.data.excerpt}
          />
        ))
      }
    </div>
  </section>
</div>
